# Acceptance-test environment template.
#
# Copy to `.env` (which is gitignored) and fill in real values:
#
#     cp .env.example .env
#     # edit .env
#     make testacc-env          # sources .env, sets TF_ACC=1, runs the suite
#
# Or source it yourself and run a single package:
#
#     set -a; source .env; set +a
#     TF_ACC=1 go test -v ./internal/services/reservation/...
#
# WARNING: acceptance tests provision REAL, BILLABLE resources and tear them
# down at the end of each test. Always point these at a dedicated test project.
# Each PreCheck skips (does not fail) the tests for a service when one of its
# required variables is unset, so you can run a subset by filling in only the
# variables that suite needs.


# =============================================================================
# Required — common credentials (needed by every acceptance suite)
# =============================================================================

# Service token scoped to the test project.
NSCALE_SERVICE_TOKEN=

# Organization, region, and project the tests run against.
NSCALE_ORGANIZATION_ID=
NSCALE_REGION_ID=
NSCALE_PROJECT_ID=


# =============================================================================
# Optional — service endpoints
# =============================================================================
#
# Leave blank to use the production defaults shown below. Override all of these
# when pointing the acceptance tests at a staging / dev cluster.
#
#   NSCALE_REGION_SERVICE_API_ENDPOINT       (default: https://region.unikorn.nscale.com)
#   NSCALE_COMPUTE_SERVICE_API_ENDPOINT      (default: https://compute.unikorn.nscale.com)
#   NSCALE_IDENTITY_SERVICE_API_ENDPOINT     (default: https://identity.unikorn.nscale.com)
#   NSCALE_RESERVATION_SERVICE_API_ENDPOINT  (default: https://reservation.unikorn.nscale.com)
#   NSCALE_STORAGE_SERVICE_API_ENDPOINT      (default: https://storage.unikorn.nscale.com)
#
# NSCALE_REGION_SERVICE_API_ENDPOINT=
# NSCALE_COMPUTE_SERVICE_API_ENDPOINT=
# NSCALE_IDENTITY_SERVICE_API_ENDPOINT=
# NSCALE_RESERVATION_SERVICE_API_ENDPOINT=
# NSCALE_STORAGE_SERVICE_API_ENDPOINT=


# =============================================================================
# Per-suite test fixtures (only needed for the suites noted)
# =============================================================================

# instance — an existing image and machine flavor to boot.
NSCALE_TEST_IMAGE_ID=
NSCALE_TEST_FLAVOR_ID=

# reservation — a public accelerator/unit capacity shape (e.g. GB300 / NVL72).
NSCALE_TEST_RESERVATION_ACCELERATOR=
NSCALE_TEST_RESERVATION_UNIT=
# placement (reservation suite) also needs NSCALE_TEST_IMAGE_ID, set above.

# file storage — an existing storage class.
NSCALE_TEST_FILE_STORAGE_CLASS_ID=

# object storage — an existing endpoint class.
NSCALE_TEST_OBJECT_STORAGE_ENDPOINT_CLASS_ID=

# identity — an existing role to assign.
NSCALE_TEST_ROLE_ID=
